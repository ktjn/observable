{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            ak.id,\n            ak.name,\n            t.name AS tenant_name,\n            ak.environment,\n            ak.created_at,\n            ak.revoked_at\n        FROM api_keys ak\n        JOIN tenants t ON t.id = ak.tenant_id\n        WHERE ak.tenant_id = $1\n        ORDER BY ak.created_at DESC\n        ",
