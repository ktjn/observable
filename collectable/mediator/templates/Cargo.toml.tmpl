# Generated by Collectable builder — do not edit manually.
# Pipeline: {{ name }}
[package]
name = "{{ name }}"
version = "0.1.0"
edition = "2021"

[[bin]]
name = "{{ name }}"
path = "src/main.rs"

[dependencies]
tokio        = { version = "1",   features = ["full"] }
serde_json   = "1"
anyhow       = "1"
tracing      = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json"] }
chrono       = { version = "0.4", features = ["serde"] }
regex        = "1"
opentelemetry       = { version = "0.26", features = ["logs"] }
opentelemetry_sdk   = { version = "0.26", features = ["rt-tokio", "logs"] }
opentelemetry-otlp  = { version = "0.26", features = ["logs", "grpc-tonic", "http-proto"] }
tonic        = "0.11"
{% if transport_kind == "tcp_syslog" or transport_kind == "udp_syslog" %}syslog_loose = "0.23"
{% endif %}{% if transport_kind == "http_webhook" %}axum = { version = "0.7", features = ["json"] }
{% endif %}{% if transport_kind == "mqtt" %}rumqttc = "0.24"
{% endif %}{% if transport_kind == "kafka" %}rdkafka = { version = "0.36", features = ["tokio", "cmake-build"] }
{% endif %}{% if parser_kind == "grok" %}grok = "2"
{% endif %}{% if parser_kind == "csv" %}csv = "1"
{% endif %}
[profile.release]
opt-level     = "z"
lto           = true
codegen-units = 1
strip         = true
panic         = "abort"
