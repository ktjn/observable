// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------
#[tokio::main]
async fn main() -> Result<()> {
    // Tracing / logging
    let log_fmt = std::env::var("COLLECTABLE_LOG_FORMAT").unwrap_or_else(|_| "json".into());
    let log_lvl = std::env::var("COLLECTABLE_LOG_LEVEL").unwrap_or_else(|_| "info".into());
    if log_fmt == "text" {
        tracing_subscriber::fmt().with_env_filter(log_lvl).init();
    } else {
        tracing_subscriber::fmt()
            .json()
            .with_env_filter(log_lvl)
            .init();
    }

    // OpenTelemetry SDK 0.27+ routes internal errors (export failures, auth rejections)
    // through the tracing subscriber automatically — no explicit error handler needed.
    // OTLP exporter — opentelemetry-otlp 0.31 builder API.
    // OTLP_ENDPOINT env var overrides the compiled-in endpoint at runtime.
    let endpoint = match std::env::var("OTLP_ENDPOINT").ok().filter(|s| !s.is_empty()) {
        Some(ep) => ep,
        None => resolve_env("{{ output.endpoint }}")?,
    };
    info!(
        endpoint = %endpoint,
        protocol = "{{ output.protocol | default(value="grpc") }}",
        "OTLP exporter configured"
    );

    // Resource attributes.
    // service.name is taken from the user-defined resource_attributes when present;
    // the pipeline name is used only as a fallback for definitions that predate this
    // change or were built without the UI.
    let mut kv_list: Vec<opentelemetry::KeyValue> = vec![
        {% if not mapping.resource_attributes or mapping.resource_attributes["service.name"] is not defined %}
        opentelemetry::KeyValue::new("service.name", "{{ name }}"),
        {% endif %}
    ];
    {% if mapping.resource_attributes %}
    {% for key, val in mapping.resource_attributes %}
    {% if val.literal %}
    kv_list.push(opentelemetry::KeyValue::new("{{ key }}", "{{ val.literal }}"));
    {% elif val.env %}
    kv_list.push(opentelemetry::KeyValue::new(
        "{{ key }}",
        std::env::var("{{ val.env }}").unwrap_or_default(),
    ));
    {% elif val.command %}
    {
        let cmd_out = std::process::Command::new("sh")
            .arg("-c")
            .arg("{{ val.command }}")
            .output()
            .map(|o| String::from_utf8_lossy(&o.stdout).trim().to_string())
            .unwrap_or_default();
        kv_list.push(opentelemetry::KeyValue::new("{{ key }}", cmd_out));
    }
    {% endif %}
    {% endfor %}
    {% endif %}
    let resource = opentelemetry_sdk::Resource::builder_empty()
        .with_attributes(kv_list)
        .build();

    let batch_config = opentelemetry_sdk::logs::BatchConfigBuilder::default()
        .with_max_export_batch_size({{ output.batch_size | default(value=100) }})
        .with_scheduled_delay(std::time::Duration::from_secs({{ output.flush_interval_secs | default(value=5) }}))
        .build();

    {% if output.protocol == "http" %}
    // Attach Authorization header if OTLP_TOKEN is set.
    let mut http_headers = std::collections::HashMap::new();
    if let Ok(token) = std::env::var("OTLP_TOKEN") {
        if !token.is_empty() {
            http_headers.insert("Authorization".to_string(), format!("Bearer {}", token));
        }
    }
    let exporter = opentelemetry_otlp::LogExporter::builder()
        .with_http()
        .with_protocol(opentelemetry_otlp::Protocol::HttpJson)
        .with_endpoint(format!("{}/v1/logs", endpoint.trim_end_matches('/')))
        .with_headers(http_headers)
        .build()
        .context("build OTLP HTTP log exporter")?;
    let processor = BatchLogProcessor::builder(exporter)
        .with_batch_config(batch_config)
        .build();
    let provider = SdkLoggerProvider::builder()
        .with_log_processor(processor)
        .with_resource(resource)
        .build();
    {% else %}
    // Default: gRPC (tonic) — used for protocol "grpc" or if protocol is unset.
    // Attach Authorization metadata if OTLP_TOKEN is set.
    let mut grpc_metadata = tonic::metadata::MetadataMap::new();
    if let Ok(token) = std::env::var("OTLP_TOKEN") {
        if !token.is_empty() {
            if let Ok(val) = tonic::metadata::MetadataValue::try_from(
                format!("Bearer {}", token)
            ) {
                grpc_metadata.insert("authorization", val);
            }
        }
    }
    let exporter = opentelemetry_otlp::LogExporter::builder()
        .with_tonic()
        .with_endpoint(&endpoint)
        .with_metadata(grpc_metadata)
        .build()
        .context("build OTLP gRPC log exporter")?;
    let processor = BatchLogProcessor::builder(exporter)
        .with_batch_config(batch_config)
        .build();
    let provider = SdkLoggerProvider::builder()
        .with_log_processor(processor)
        .with_resource(resource)
        .build();
    {% endif %}
    let provider = Arc::new(provider);

    info!(
        pipeline = "{{ name }}",
        transport = "{{ transport_kind }}",
        parser = "{{ parser_kind }}",
        "collectable starting"
    );

    run_transport(provider.clone()).await?;

    provider.shutdown()?;
    Ok(())
}
