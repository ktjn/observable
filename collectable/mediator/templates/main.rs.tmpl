{% if transport_kind == "tcp_syslog" %}
async fn run_transport(provider: Arc<SdkLoggerProvider>) -> Result<()> {
    use tokio::io::AsyncBufReadExt;
    let host = resolve_env("{{ transport_params.host | default(value="0.0.0.0") }}")?;
    let port = resolve_env("{{ transport_params.port | default(value="${TRANSPORT_PORT:-514}") }}")?;
    let addr = format!("{}:{}", host, port);
    let listener = tokio::net::TcpListener::bind(&addr)
        .await
        .with_context(|| format!("bind TCP {}", addr))?;
    info!("tcp_syslog listening on {}", addr);
    loop {
        let (socket, peer) = listener.accept().await?;
        let prov = provider.clone();
        tokio::spawn(async move {
            let reader = tokio::io::BufReader::new(socket);
            let mut lines = reader.lines();
            while let Ok(Some(line)) = lines.next_line().await {
                if line.is_empty() {
                    continue;
                }
                // Strip RFC 3164/5424 syslog header; pass message body to parser
                let parsed = parse_syslog(&line, syslog_loose::Variant::Either);
                let msg = parsed.msg.trim();
                let mut fields = parse_frame(msg);
                if let Some(h) = parsed.hostname {
                    fields.entry("syslog.hostname".into()).or_insert_with(|| h.to_string());
                }
                if let Some(a) = parsed.appname {
                    fields.entry("syslog.appname".into()).or_insert_with(|| a.to_string());
                }
                emit_record(&fields, &prov);
            }
            info!("peer {} disconnected", peer);
        });
    }
}

{% elif transport_kind == "udp_syslog" %}
async fn run_transport(provider: Arc<SdkLoggerProvider>) -> Result<()> {
    let host = resolve_env("{{ transport_params.host | default(value="0.0.0.0") }}")?;
    let port = resolve_env("{{ transport_params.port | default(value="${TRANSPORT_PORT:-514}") }}")?;
    let addr = format!("{}:{}", host, port);
    let socket = tokio::net::UdpSocket::bind(&addr)
        .await
        .with_context(|| format!("bind UDP {}", addr))?;
    info!("udp_syslog listening on {}", addr);
    let mut buf = vec![0u8; 65536];
    loop {
        let (len, _peer) = socket.recv_from(&mut buf).await?;
        let line = String::from_utf8_lossy(&buf[..len]).to_string();
        let parsed = parse_syslog(&line, syslog_loose::Variant::Either);
        let msg = parsed.msg.trim();
        let mut fields = parse_frame(msg);
        if let Some(h) = parsed.hostname {
            fields.entry("syslog.hostname".into()).or_insert_with(|| h.to_string());
        }
        if let Some(a) = parsed.appname {
            fields.entry("syslog.appname".into()).or_insert_with(|| a.to_string());
        }
        emit_record(&fields, &provider);
    }
}

{% elif transport_kind == "http_webhook" %}
async fn run_transport(provider: Arc<SdkLoggerProvider>) -> Result<()> {
    use tokio::sync::mpsc;
    let (tx, mut rx) = mpsc::channel::<String>(1024);
    let path = "{{ transport_params.path | default(value="/logs") }}".to_string();
    let app = {
        let tx2 = tx.clone();
        let path2 = path.clone();
        Router::new().route(
            &path2,
            post(move |body: Bytes| {
                let tx3 = tx2.clone();
                async move {
                    match String::from_utf8(body.to_vec()) {
                        Ok(s) => {
                            let _ = tx3.send(s).await;
                            StatusCode::OK
                        }
                        Err(_) => StatusCode::BAD_REQUEST,
                    }
                }
            }),
        )
    };
    let host = resolve_env("{{ transport_params.host | default(value="0.0.0.0") }}")?;
    let port = resolve_env("{{ transport_params.port | default(value="${TRANSPORT_PORT:-8080}") }}")?;
    let addr: std::net::SocketAddr = format!("{}:{}", host, port).parse()?;
    info!("http_webhook listening on {} path={}", addr, path);
    let listener = tokio::net::TcpListener::bind(addr).await?;
    tokio::spawn(async move {
        axum::serve(listener, app).await.expect("axum serve");
    });
    while let Some(body) = rx.recv().await {
        for line in body.lines() {
            if !line.is_empty() {
                let fields = parse_frame(line);
                emit_record(&fields, &provider);
            }
        }
    }
    Ok(())
}

{% elif transport_kind == "file_tail" %}
async fn run_transport(provider: Arc<SdkLoggerProvider>) -> Result<()> {
    use tokio::io::AsyncBufReadExt;
    let path = resolve_env("{{ transport_params.path | default(value="${FILE_PATH}") }}")?;
    info!("file_tail reading {}", path);
    let file = tokio::fs::File::open(&path)
        .await
        .with_context(|| format!("open file {}", path))?;
    let reader = tokio::io::BufReader::new(file);
    let mut lines = reader.lines();
    loop {
        match lines.next_line().await {
            Ok(Some(line)) if !line.is_empty() => {
                let fields = parse_frame(&line);
                if fields.is_empty() {
                    warn!(raw = %line, "parse produced no fields — line skipped");
                } else {
                    emit_record(&fields, &provider);
                }
            }
            Ok(Some(_)) => {}
            Ok(None) => break,
            Err(e) => {
                error!(error = %e, path = %path, "file read error");
                break;
            }
        }
    }
    // Simple tail: poll for new data
    loop {
        tokio::time::sleep(std::time::Duration::from_millis(200)).await;
        // Re-open to catch rotation; for production use notify/inotify
        if let Ok(f) = tokio::fs::File::open(&path).await {
            let mut lines2 = tokio::io::BufReader::new(f).lines();
            while let Ok(Some(line)) = lines2.next_line().await {
                if !line.is_empty() {
                    let fields = parse_frame(&line);
                    emit_record(&fields, &provider);
                }
            }
        }
    }
}

{% elif transport_kind == "mqtt" %}
async fn run_transport(provider: Arc<SdkLoggerProvider>) -> Result<()> {
    let broker = resolve_env("{{ transport_params.broker | default(value="${MQTT_BROKER}") }}")?;
    let topic = resolve_env("{{ transport_params.topic | default(value="${MQTT_TOPIC}") }}")?;
    let client_id = format!("collectable-{{ name }}-{}", std::process::id());
    let broker_clean = broker
        .trim_start_matches("mqtt://")
        .trim_start_matches("tcp://");
    let (host, port_str) = broker_clean.split_once(':').unwrap_or((broker_clean, "1883"));
    let port: u16 = port_str.parse().unwrap_or(1883);
    let mut mqttopts = MqttOptions::new(&client_id, host, port);
    mqttopts.set_keep_alive(std::time::Duration::from_secs(30));
    {% if transport_params.username %}
    {
        let username = resolve_env("{{ transport_params.username }}")?;
        let password = resolve_env("{{ transport_params.password | default(value="") }}")?;
        mqttopts.set_credentials(username, password);
    }
    {% endif %}
    let (client, mut eventloop) = AsyncClient::new(mqttopts, 64);
    client.subscribe(&topic, QoS::AtMostOnce).await?;
    info!("mqtt subscribed to {} via {}", topic, broker);
    loop {
        match eventloop.poll().await {
            Ok(rumqttc::Event::Incoming(rumqttc::Packet::Publish(msg))) => {
                let payload = String::from_utf8_lossy(&msg.payload).to_string();
                for line in payload.lines() {
                    if !line.is_empty() {
                        let fields = parse_frame(line);
                        if fields.is_empty() {
                            warn!(raw = %line, "parse produced no fields — line skipped");
                            continue;
                        }
                        emit_record(&fields, &provider);
                    }
                }
            }
            Ok(_) => {}
            Err(e) => {
                error!("mqtt error: {}", e);
                tokio::time::sleep(std::time::Duration::from_secs(5)).await;
            }
        }
    }
}

{% elif transport_kind == "kafka" %}
async fn run_transport(provider: Arc<SdkLoggerProvider>) -> Result<()> {
    let brokers = resolve_env("{{ transport_params.brokers | default(value="${KAFKA_BROKERS}") }}")?;
    let topic = resolve_env("{{ transport_params.topic | default(value="${KAFKA_TOPIC}") }}")?;
    let group_id =
        resolve_env("{{ transport_params.group_id | default(value="${KAFKA_GROUP_ID:-collectable}") }}")?;
    let consumer: StreamConsumer = ClientConfig::new()
        .set("bootstrap.servers", &brokers)
        .set("group.id", &group_id)
        .set("auto.offset.reset", "latest")
        .create()
        .context("create Kafka consumer")?;
    consumer
        .subscribe(&[topic.as_str()])
        .context("subscribe to Kafka topic")?;
    info!("kafka consuming topic {} from {}", topic, brokers);
    loop {
        match consumer.recv().await {
            Ok(msg) => {
                if let Some(payload) = msg.payload() {
                    let s = String::from_utf8_lossy(payload).to_string();
                    for line in s.lines() {
                        if !line.is_empty() {
                            let fields = parse_frame(line);
                            if fields.is_empty() {
                                warn!(raw = %line, "parse produced no fields — line skipped");
                                continue;
                            }
                            emit_record(&fields, &provider);
                        }
                    }
                }
            }
            Err(e) => {
                error!("kafka recv error: {}", e);
            }
        }
    }
}

{% elif transport_kind == "stdin" %}
async fn run_transport(provider: Arc<SdkLoggerProvider>) -> Result<()> {
    use tokio::io::AsyncBufReadExt;
    let reader = tokio::io::BufReader::new(tokio::io::stdin());
    let mut lines = reader.lines();
    info!("reading from stdin");
    loop {
        match lines.next_line().await {
            Ok(Some(line)) => {
                if !line.is_empty() {
                    let fields = parse_frame(&line);
                    if fields.is_empty() {
                        warn!(raw = %line, "parse produced no fields — line skipped");
                        continue;
                    }
                    emit_record(&fields, &provider);
                }
            }
            Ok(None) => {
                info!("stdin closed — exiting");
                break;
            }
            Err(e) => {
                error!(error = %e, "stdin read error — exiting");
                break;
            }
        }
    }
    Ok(())
}

