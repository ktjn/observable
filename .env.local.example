# Copy to .env.local (gitignored). No production secrets required.
CH_USER=default
CH_PASSWORD=
CH_HOST=localhost
CH_PORT=8123
CH_DB=observable

PG_USER=observable
PG_PASSWORD=observable
PG_DB=observable
PG_HOST=localhost
PG_PORT=5432
DATABASE_URL=postgres://observable:observable@localhost:5432/observable

REDPANDA_BROKERS=localhost:9092
INGEST_TOPIC=telemetry.raw

OPENFGA_URL=http://localhost:8080

# Service ports (local only)
INGEST_GATEWAY_PORT=4317
AUTH_SERVICE_PORT=4318
QUERY_API_PORT=8090
FRONTEND_PORT=5173

# Self-observability routing.
# Use "self" for local recursive platform telemetry, or "observer_instance"
# when sending platform telemetry to a second Observable deployment.
OBSERVABLE_SELF_OBSERVABILITY_MODE=self
OBSERVABLE_SELF_OBSERVABILITY_OTLP_ENDPOINT=http://ingest-gateway:4318
